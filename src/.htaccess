RewriteEngine On

# ── API Proxy via PHP (no mod_proxy needed) ──
# Routes API calls to proxy.php which forwards to beta/staging servers

RewriteCond %{REQUEST_URI} ^/(partner-api|b2b-api|wallet-api)/
RewriteRule ^(.*)$ /proxy.php [L,QSA]

# ── SPA Fallback ──
# All non-file, non-directory requests go to index.html (Angular handles routing)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.html [L]
