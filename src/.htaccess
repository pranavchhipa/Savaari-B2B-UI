RewriteEngine On

# ── API Proxy Rewrites (same as vercel.json but for Apache) ──
# These forward /partner-api/*, /b2b-api/*, /wallet-api/* to Savaari servers

# Partner API → api.savaari.com
RewriteCond %{REQUEST_URI} ^/partner-api/(.*)$
RewriteRule ^partner-api/(.*)$ https://api.savaari.com/partner_api/public/$1 [P,L]

# B2B API → api23.savaari.com
RewriteCond %{REQUEST_URI} ^/b2b-api/(.*)$
RewriteRule ^b2b-api/(.*)$ https://api23.savaari.com/$1 [P,L]

# Wallet API → apiext.savaari.com
RewriteCond %{REQUEST_URI} ^/wallet-api/(.*)$
RewriteRule ^wallet-api/(.*)$ https://apiext.savaari.com/wallet/public/$1 [P,L]

# ── SPA Fallback ──
# All non-file, non-directory requests go to index.php (Angular handles routing)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.php [L]
